---
// CSS-only animated Notch HUD demo showing the recording → transcribing → success loop
---

<div class="flex flex-col items-center gap-3">
  <p class="text-xs tracking-wider uppercase" style="color: var(--brand-muted); opacity: 0.6;">
    Notch HUD Overlay
  </p>

  <!-- Notch container -->
  <div class="notch-demo-wrapper">
    <div class="notch-demo" id="notch-demo">
      <!-- Phase: Recording (waveform bars) -->
      <div class="notch-phase notch-phase-recording" id="notch-recording">
        <!-- App icon placeholder -->
        <div
          class="w-5 h-5 rounded-[5px] mr-2 flex-shrink-0 flex items-center justify-center"
          style="background: rgba(255,255,255,0.15);"
        >
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="opacity: 0.7;">
            <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
            <line x1="8" y1="21" x2="16" y2="21"></line>
            <line x1="12" y1="17" x2="12" y2="21"></line>
          </svg>
        </div>

        <!-- Waveform bars -->
        <div class="flex items-center gap-[3px] h-7">
          <div class="notch-bar" style="--bar-height: 12px; animation-delay: 0s;"></div>
          <div class="notch-bar" style="--bar-height: 20px; animation-delay: 0.15s;"></div>
          <div class="notch-bar" style="--bar-height: 16px; animation-delay: 0.3s;"></div>
          <div class="notch-bar" style="--bar-height: 24px; animation-delay: 0.1s;"></div>
          <div class="notch-bar" style="--bar-height: 14px; animation-delay: 0.25s;"></div>
          <div class="notch-bar" style="--bar-height: 18px; animation-delay: 0.05s;"></div>
        </div>

        <!-- Timer -->
        <span
          class="ml-3 text-xs tabular-nums"
          style="color: rgba(255,255,255,0.6); font-family: 'JetBrains Mono', 'SF Mono', monospace; font-variant-numeric: tabular-nums;"
          id="notch-timer"
        >
          0:02
        </span>
      </div>

      <!-- Phase: Transcribing (dots) -->
      <div class="notch-phase notch-phase-transcribing hidden" id="notch-transcribing">
        <div class="flex items-center gap-[6px]">
          <div class="notch-dot" style="animation-delay: 0s;"></div>
          <div class="notch-dot" style="animation-delay: 0.3s;"></div>
          <div class="notch-dot" style="animation-delay: 0.6s;"></div>
          <div class="notch-dot" style="animation-delay: 0.9s;"></div>
          <div class="notch-dot" style="animation-delay: 1.2s;"></div>
        </div>
      </div>

      <!-- Phase: Success (checkmark) -->
      <div class="notch-phase notch-phase-success hidden" id="notch-success">
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="#22c55e"
          stroke-width="3"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="notch-check"
        >
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
      </div>
    </div>
  </div>
</div>

<style>
  .notch-demo-wrapper {
    filter: drop-shadow(0 4px 16px rgba(0, 0, 0, 0.4));
  }

  .notch-phase {
    display: flex;
    align-items: center;
    justify-content: center;
    position: absolute;
    inset: 0;
    padding: 0 24px;
    transition: opacity 0.25s ease;
  }

  .notch-phase.hidden {
    opacity: 0;
    pointer-events: none;
  }

  .notch-phase:not(.hidden) {
    opacity: 1;
  }

  .notch-check polyline {
    stroke-dasharray: 30;
    stroke-dashoffset: 30;
  }

  .notch-phase-success:not(.hidden) .notch-check polyline {
    animation: demo-draw-check 0.4s ease-out 0.1s forwards;
  }

  @keyframes demo-draw-check {
    to {
      stroke-dashoffset: 0;
    }
  }
</style>

<script>
  // Simple state machine for the Notch HUD demo loop
  const phases = ["recording", "transcribing", "success"] as const;
  const durations = { recording: 2800, transcribing: 1800, success: 1200 };
  let currentPhase = 0;

  function showPhase(index: number) {
    const recording = document.getElementById("notch-recording");
    const transcribing = document.getElementById("notch-transcribing");
    const success = document.getElementById("notch-success");
    const notch = document.getElementById("notch-demo");

    if (!recording || !transcribing || !success || !notch) return;

    const els = [recording, transcribing, success];
    els.forEach((el, i) => {
      if (i === index) {
        el.classList.remove("hidden");
      } else {
        el.classList.add("hidden");
      }
    });

    // Success glow effect
    if (index === 2) {
      notch.style.filter =
        "drop-shadow(0 0 8px rgba(34, 197, 94, 0.5))";
      setTimeout(() => {
        notch.style.filter = "";
      }, 600);
    }
  }

  function loop() {
    showPhase(currentPhase);
    const phase = phases[currentPhase];
    setTimeout(() => {
      currentPhase = (currentPhase + 1) % phases.length;
      loop();
    }, durations[phase]);
  }

  // Start after a short delay
  setTimeout(loop, 1000);

  // Timer counter for recording phase
  let timerVal = 0;
  const timerEl = document.getElementById("notch-timer");
  setInterval(() => {
    if (currentPhase === 0 && timerEl) {
      timerVal++;
      const secs = timerVal % 5;
      timerEl.textContent = `0:0${secs + 1}`;
    }
  }, 800);
</script>
