---
interface Props {
  type?: "info" | "tip" | "warn" | "note";
  title?: string;
  titleZh?: string;
}

const { type = "info", title, titleZh } = Astro.props;

const styles: Record<string, { border: string; bg: string; icon: string; iconColor: string; defaultTitle: { en: string; zh: string } }> = {
  info: {
    border: "rgba(59, 130, 246, 0.5)",
    bg: "rgba(59, 130, 246, 0.08)",
    iconColor: "#60a5fa",
    icon: "M13 16h-1v-4h-1m1-4h.01M12 2a10 10 0 100 20 10 10 0 000-20z",
    defaultTitle: { en: "Note", zh: "說明" },
  },
  tip: {
    border: "rgba(34, 197, 94, 0.5)",
    bg: "rgba(34, 197, 94, 0.08)",
    iconColor: "#4ade80",
    icon: "M9 12l2 2 4-4m6 2a10 10 0 11-20 0 10 10 0 0120 0z",
    defaultTitle: { en: "Tip", zh: "小技巧" },
  },
  warn: {
    border: "rgba(251, 191, 36, 0.5)",
    bg: "rgba(251, 191, 36, 0.08)",
    iconColor: "#fbbf24",
    icon: "M12 9v2m0 4h.01M12 2 1 21h22L12 2z",
    defaultTitle: { en: "Caution", zh: "注意" },
  },
  note: {
    border: "rgba(161, 178, 196, 0.5)",
    bg: "rgba(161, 178, 196, 0.06)",
    iconColor: "#a1b2c4",
    icon: "M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5M18.5 2.5a2.121 2.121 0 113 3L12 15l-4 1 1-4 9.5-9.5z",
    defaultTitle: { en: "Note", zh: "備註" },
  },
};

const s = styles[type];
const enTitle = title ?? s.defaultTitle.en;
const zhTitle = titleZh ?? s.defaultTitle.zh;
---

<div
  class="docs-callout my-4 rounded-lg p-4 flex gap-3"
  style={`border: 1px solid ${s.border}; background: ${s.bg};`}
>
  <svg
    width="20"
    height="20"
    viewBox="0 0 24 24"
    fill="none"
    stroke={s.iconColor}
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="flex-shrink-0 mt-0.5"
  >
    <path d={s.icon}></path>
  </svg>
  <div class="flex-1 min-w-0">
    <div class="font-semibold mb-1" style={`color: ${s.iconColor};`}>
      <span class="lang-en">{enTitle}</span><span class="lang-zh">{zhTitle}</span>
    </div>
    <div class="text-sm" style="color: var(--brand-foreground);">
      <slot />
    </div>
  </div>
</div>

<style>
  .docs-callout :global(p) {
    margin: 0.25rem 0;
  }
  .docs-callout :global(p:first-child) {
    margin-top: 0;
  }
  .docs-callout :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
