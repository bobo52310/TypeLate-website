---
// Static-site search powered by Pagefind. The pagefind index is
// generated by the `postbuild` script and served from /_pagefind/.
// In dev mode the index doesn't exist yet — the input is disabled.
---

<div class="docs-search relative" data-docs-search>
  <label class="sr-only" for="docs-search-input">
    <span class="lang-en">Search documentation</span>
    <span class="lang-zh">搜尋文件</span>
  </label>
  <div class="relative">
    <svg
      class="absolute left-2.5 top-1/2 -translate-y-1/2 pointer-events-none"
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      style="color: var(--brand-muted);"
    >
      <circle cx="11" cy="11" r="8"></circle>
      <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
    </svg>
    <input
      id="docs-search-input"
      type="search"
      autocomplete="off"
      spellcheck="false"
      placeholder="Search…"
      class="w-full text-sm pl-8 pr-3 py-1.5 rounded-md transition-colors"
      style="background: var(--brand-card); border: 1px solid var(--brand-border); color: var(--brand-foreground);"
      data-search-input
    />
  </div>

  <div
    class="docs-search-results absolute left-0 right-0 mt-1 max-h-[60vh] overflow-y-auto rounded-md hidden z-30"
    style="background: var(--brand-bg); border: 1px solid var(--brand-border); box-shadow: 0 6px 24px rgba(0,0,0,0.4);"
    data-search-results
  >
  </div>
</div>

<style>
  .docs-search-results :global(.docs-search-result) {
    display: block;
    padding: 0.6rem 0.75rem;
    border-bottom: 1px solid var(--brand-border);
    color: var(--brand-foreground);
    text-decoration: none;
    transition: background 0.15s;
  }
  .docs-search-results :global(.docs-search-result:last-child) {
    border-bottom: 0;
  }
  .docs-search-results :global(.docs-search-result:hover),
  .docs-search-results :global(.docs-search-result.is-active) {
    background: rgba(251, 191, 36, 0.06);
  }
  .docs-search-results :global(.docs-search-result-title) {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--brand-foreground);
  }
  .docs-search-results :global(.docs-search-result-excerpt) {
    margin-top: 0.2rem;
    font-size: 0.75rem;
    color: var(--brand-muted);
    line-height: 1.45;
  }
  .docs-search-results :global(.docs-search-result-excerpt mark) {
    background: rgba(251, 191, 36, 0.2);
    color: var(--brand-gold-light);
    border-radius: 2px;
    padding: 0 1px;
  }
  .docs-search-results :global(.docs-search-empty) {
    padding: 0.75rem;
    color: var(--brand-muted);
    font-size: 0.75rem;
  }
</style>

<script>
  type PagefindResult = {
    id: string;
    data: () => Promise<{
      url: string;
      excerpt: string;
      meta: { title?: string };
    }>;
  };

  type PagefindAPI = {
    search: (
      query: string,
    ) => Promise<{ results: PagefindResult[] }>;
  };

  // Pagefind's bundle is generated at /pagefind/pagefind.js; the
  // script tag below loads it dynamically only when the input is
  // first focused, so the dev experience isn't disrupted by 404s.
  let pagefindPromise: Promise<PagefindAPI | null> | null = null;

  function loadPagefind(): Promise<PagefindAPI | null> {
    if (pagefindPromise) return pagefindPromise;
    pagefindPromise = (async () => {
      try {
        const mod = (await import(
          /* @vite-ignore */ "/pagefind/pagefind.js"
        )) as PagefindAPI;
        return mod;
      } catch (e) {
        console.warn("Pagefind not available (run `npm run build` first):", e);
        return null;
      }
    })();
    return pagefindPromise;
  }

  function debounce<T extends (...args: never[]) => unknown>(
    fn: T,
    ms: number,
  ): (...args: Parameters<T>) => void {
    let t: number | undefined;
    return (...args) => {
      if (t !== undefined) window.clearTimeout(t);
      t = window.setTimeout(() => fn(...args), ms);
    };
  }

  document.querySelectorAll<HTMLElement>("[data-docs-search]").forEach((root) => {
    const input = root.querySelector<HTMLInputElement>("[data-search-input]");
    const results = root.querySelector<HTMLElement>("[data-search-results]");
    if (!input || !results) return;

    let activeIdx = -1;

    function render(items: { url: string; title: string; excerpt: string }[]) {
      if (!results) return;
      if (items.length === 0) {
        results.innerHTML =
          '<div class="docs-search-empty"><span class="lang-en">No matches.</span><span class="lang-zh">沒有符合結果。</span></div>';
        results.classList.remove("hidden");
        return;
      }
      results.innerHTML = items
        .map(
          (r, i) => `
            <a class="docs-search-result${i === 0 ? " is-active" : ""}" href="${r.url}" data-result-idx="${i}">
              <div class="docs-search-result-title">${r.title}</div>
              <div class="docs-search-result-excerpt">${r.excerpt}</div>
            </a>
          `,
        )
        .join("");
      results.classList.remove("hidden");
      activeIdx = 0;
    }

    function hide() {
      if (!results) return;
      results.classList.add("hidden");
      activeIdx = -1;
    }

    const runSearch = debounce(async (q: string) => {
      if (!q.trim()) {
        hide();
        return;
      }
      const pf = await loadPagefind();
      if (!pf) {
        hide();
        return;
      }
      try {
        const search = await pf.search(q);
        const top = await Promise.all(
          search.results.slice(0, 8).map(async (r) => {
            const data = await r.data();
            const url = data.url.replace(/\.html$/, "/").replace(/\/index\/?$/, "/");
            return {
              url,
              title: data.meta?.title || url,
              excerpt: data.excerpt,
            };
          }),
        );
        render(top);
      } catch (e) {
        console.warn("Pagefind search failed:", e);
        hide();
      }
    }, 150);

    input.addEventListener("input", () => runSearch(input.value));
    input.addEventListener("focus", () => {
      if (input.value.trim()) runSearch(input.value);
    });

    document.addEventListener("click", (e) => {
      if (!root.contains(e.target as Node)) hide();
    });

    input.addEventListener("keydown", (e) => {
      if (!results || results.classList.contains("hidden")) return;
      const links = results.querySelectorAll<HTMLAnchorElement>(".docs-search-result");
      if (links.length === 0) return;

      if (e.key === "ArrowDown") {
        e.preventDefault();
        activeIdx = Math.min(activeIdx + 1, links.length - 1);
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        activeIdx = Math.max(activeIdx - 1, 0);
      } else if (e.key === "Enter") {
        e.preventDefault();
        if (activeIdx >= 0) links[activeIdx].click();
      } else if (e.key === "Escape") {
        hide();
        input.blur();
        return;
      } else {
        return;
      }
      links.forEach((l, i) => l.classList.toggle("is-active", i === activeIdx));
      links[activeIdx]?.scrollIntoView({ block: "nearest" });
    });
  });
</script>
