---
const GITHUB_URL = "https://github.com/bobo52310/TypeLate";
const ISSUES_URL = `${GITHUB_URL}/issues?q=label%3Awishlist`;
---

<section class="pb-24 px-6">
  <div class="max-w-4xl mx-auto">
    <!-- Controls: Filter tabs + Sort -->
    <div class="fade-in flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-8">
      <!-- Filter tabs -->
      <div class="flex gap-1 rounded-lg p-1" style="background: var(--brand-card); border: 1px solid var(--brand-border);">
        <button data-filter="shipped" class="wishlist-tab active px-3 py-1.5 rounded-md text-xs font-medium transition-colors">
          <span class="lang-en">Shipped</span><span class="lang-zh">已上線</span>
        </button>
        <button data-filter="all" class="wishlist-tab px-3 py-1.5 rounded-md text-xs font-medium transition-colors">
          <span class="lang-en">All</span><span class="lang-zh">全部</span>
        </button>
        <button data-filter="open" class="wishlist-tab px-3 py-1.5 rounded-md text-xs font-medium transition-colors">
          <span class="lang-en">Open</span><span class="lang-zh">許願中</span>
        </button>
        <button data-filter="in-progress" class="wishlist-tab px-3 py-1.5 rounded-md text-xs font-medium transition-colors">
          <span class="lang-en">In Progress</span><span class="lang-zh">開發中</span>
        </button>
      </div>

      <!-- Sort -->
      <div class="flex items-center gap-2 text-xs" style="color: var(--brand-muted);">
        <span class="lang-en">Sort:</span><span class="lang-zh">排序：</span>
        <button data-sort="votes" class="wishlist-sort active font-medium transition-colors">
          <span class="lang-en">Most Voted</span><span class="lang-zh">最多票</span>
        </button>
        <span style="opacity: 0.3;">|</span>
        <button data-sort="newest" class="wishlist-sort font-medium transition-colors">
          <span class="lang-en">Newest</span><span class="lang-zh">最新</span>
        </button>
      </div>
    </div>

    <!-- Card grid -->
    <div id="wishlist-grid" class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <!-- Skeleton loading -->
      {[1, 2, 3, 4].map(() => (
        <div class="wishlist-skeleton rounded-2xl p-6" style="background: var(--brand-card); border: 1px solid var(--brand-border);">
          <div class="flex items-start gap-4">
            <div class="skeleton-pulse w-12 h-12 rounded-xl shrink-0"></div>
            <div class="flex-1 space-y-3">
              <div class="skeleton-pulse h-4 rounded w-3/4"></div>
              <div class="skeleton-pulse h-3 rounded w-full"></div>
              <div class="skeleton-pulse h-3 rounded w-1/2"></div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Empty state (hidden by default) -->
    <div id="wishlist-empty" class="hidden text-center py-16">
      <div class="w-16 h-16 rounded-2xl flex items-center justify-center mx-auto mb-4" style="background: rgba(251, 191, 36, 0.1); color: var(--brand-gold);">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
      </div>
      <h3 class="text-lg font-semibold mb-2">
        <span class="lang-en">All caught up!</span>
        <span class="lang-zh">全部實現了！</span>
      </h3>
      <p class="text-sm mb-6" style="color: var(--brand-muted);">
        <span class="lang-en">Every request has been built. Got a new idea? You could be the first!</span>
        <span class="lang-zh">所有許願都已實作完成。有新點子嗎？來許下一個願望吧！</span>
      </p>
    </div>

    <!-- Error state (hidden by default) -->
    <div id="wishlist-error" class="hidden text-center py-16">
      <div class="w-16 h-16 rounded-2xl flex items-center justify-center mx-auto mb-4" style="background: rgba(239, 68, 68, 0.1); color: #ef4444;">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
      </div>
      <h3 class="text-lg font-semibold mb-2">
        <span class="lang-en">Couldn't load wishlist</span>
        <span class="lang-zh">無法載入許願池</span>
      </h3>
      <p class="text-sm mb-6" style="color: var(--brand-muted);">
        <span class="lang-en">GitHub API may be rate-limited. Try again later or view directly on GitHub.</span>
        <span class="lang-zh">GitHub API 可能已達速率限制。請稍後再試或直接前往 GitHub 查看。</span>
      </p>
      <div class="flex items-center justify-center gap-3">
        <button id="wishlist-retry" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium transition-colors" style="border: 1px solid var(--brand-border); color: var(--brand-foreground);">
          <span class="lang-en">Retry</span><span class="lang-zh">重試</span>
        </button>
        <a href={ISSUES_URL} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium transition-colors" style="border: 1px solid var(--brand-border); color: var(--brand-foreground);">
          <span class="lang-en">View on GitHub</span><span class="lang-zh">前往 GitHub</span>
        </a>
      </div>
    </div>

    <!-- Noscript fallback -->
    <noscript>
      <div class="text-center py-16">
        <p class="text-sm mb-4" style="color: var(--brand-muted);">
          JavaScript is required to load the wishlist. View feature requests directly on GitHub:
        </p>
        <a href={ISSUES_URL} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium" style="border: 1px solid var(--brand-border); color: var(--brand-foreground);">
          View on GitHub
        </a>
      </div>
    </noscript>

    <!-- Footer link -->
    <div id="wishlist-footer" class="hidden text-center mt-8">
      <a href={ISSUES_URL} target="_blank" rel="noopener noreferrer" class="text-xs transition-colors hover:text-[var(--brand-foreground)]" style="color: var(--brand-muted);">
        <span class="lang-en">View all on GitHub &rarr;</span>
        <span class="lang-zh">在 GitHub 上查看全部 &rarr;</span>
      </a>
    </div>
  </div>
</section>

<style>
  .wishlist-tab {
    color: var(--brand-muted);
  }
  .wishlist-tab.active {
    background: rgba(251, 191, 36, 0.15);
    color: var(--brand-gold);
  }
  .wishlist-tab:not(.active):hover {
    color: var(--brand-foreground);
  }
  .wishlist-sort {
    color: var(--brand-muted);
  }
  .wishlist-sort.active {
    color: var(--brand-gold);
  }
  .wishlist-sort:not(.active):hover {
    color: var(--brand-foreground);
  }
</style>

<script>
  const API_URL = "https://api.github.com/repos/bobo52310/TypeLate/issues";
  const CACHE_KEY = "wishlist-cache";
  const CACHE_TTL = 5 * 60 * 1000; // 5 minutes

  interface GitHubIssue {
    id: number;
    title: string;
    body: string | null;
    html_url: string;
    state: string;
    created_at: string;
    comments: number;
    reactions: { "+1": number };
    labels: Array<{ name: string }>;
    user: { login: string; avatar_url: string } | null;
  }

  interface CacheData {
    timestamp: number;
    issues: GitHubIssue[];
  }

  interface BuiltInFeature {
    title: string;
    titleZh: string;
    desc: string;
    descZh: string;
    icon: string;
  }

  const SHIPPED_FEATURES: BuiltInFeature[] = [
    {
      title: "Google Drive Sync",
      titleZh: "Google Drive 雲端同步",
      desc: "Sync vocabulary across devices",
      descZh: "跨裝置同步詞彙庫",
      icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 19.5h20L12 2z"/><path d="M2 19.5l10-4.5 10 4.5"/><path d="M12 2l5 13H7L12 2z"/></svg>`,
    },
    {
      title: "Import Vocabulary via URL",
      titleZh: "貼上 URL 即可匯入術語",
      desc: "Paste a link, get domain terms",
      descZh: "貼上連結即可匯入專業術語",
      icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>`,
    },
    {
      title: "Smart Vocabulary",
      titleZh: "智慧詞彙庫",
      desc: "Context-aware term matching",
      descZh: "上下文感知的術語匹配",
      icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>`,
    },
    {
      title: "Analytics Dashboard",
      titleZh: "數據儀表板",
      desc: "Usage trends and cost breakdown",
      descZh: "使用趨勢與費用明細",
      icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M18 17V9"/><path d="M13 17V5"/><path d="M8 17v-3"/></svg>`,
    },
    {
      title: "Sound Feedback",
      titleZh: "聲音回饋",
      desc: "5 themes + custom sound support",
      descZh: "5 組主題 + 自訂音效",
      icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>`,
    },
    {
      title: "Auto-Updater",
      titleZh: "自動更新",
      desc: "Preview changelog before updating",
      descZh: "更新前可預覽更新日誌",
      icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/><path d="M16 16h5v5"/></svg>`,
    },
    {
      title: "Hallucination Filter",
      titleZh: "幻覺過濾器",
      desc: "Blocks AI-fabricated content",
      descZh: "過濾 AI 生成的幻覺內容",
      icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 12 2 2 4-4"/></svg>`,
    },
    {
      title: "Multi-Model Support",
      titleZh: "多模型支援",
      desc: "Groq, OpenAI, local models",
      descZh: "Groq、OpenAI、本地模型",
      icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2"/><path d="M9 9h6v6H9z"/><path d="M9 1v3"/><path d="M15 1v3"/><path d="M9 20v3"/><path d="M15 20v3"/><path d="M20 9h3"/><path d="M20 14h3"/><path d="M1 9h3"/><path d="M1 14h3"/></svg>`,
    },
    {
      title: "Clipboard Preservation",
      titleZh: "剪貼簿保留",
      desc: "Keep clipboard intact after paste",
      descZh: "貼上後保留原剪貼簿內容",
      icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="8" y="2" width="8" height="4" rx="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/></svg>`,
    },
    {
      title: "Recording Management",
      titleZh: "錄音管理",
      desc: "Retention, re-transcribe, storage stats",
      descZh: "保留策略、重新轉錄、儲存統計",
      icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="22"/></svg>`,
    },
    {
      title: "Silence Detection",
      titleZh: "靜音偵測",
      desc: "Auto-stop on prolonged silence",
      descZh: "長時間靜音自動停止錄音",
      icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>`,
    },
    {
      title: "Accessibility (WCAG)",
      titleZh: "無障礙設計 (WCAG)",
      desc: "Full keyboard nav & reduced motion",
      descZh: "完整鍵盤導航與降低動態",
      icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="16" cy="4" r="1"/><path d="m18 8-4-1-4 5 3 3 1 5"/><path d="m6 13 4-4"/><path d="m9 18-1-4"/></svg>`,
    },
  ];

  let allIssues: GitHubIssue[] = [];
  let currentFilter = "shipped";
  let currentSort = "votes";

  // --- Helpers ---

  function stripMarkdown(text: string): string {
    return text
      .replace(/#{1,6}\s/g, "")
      .replace(/\*{1,3}(.*?)\*{1,3}/g, "$1")
      .replace(/\[([^\]]*)\]\([^)]*\)/g, "$1")
      .replace(/`{1,3}[^`]*`{1,3}/g, "")
      .replace(/^[-*+]\s/gm, "")
      .replace(/!\[.*?\]\(.*?\)/g, "")
      .replace(/\n{2,}/g, " ")
      .replace(/\n/g, " ")
      .trim();
  }

  function timeAgo(dateStr: string): { en: string; zh: string } {
    const seconds = Math.floor((Date.now() - new Date(dateStr).getTime()) / 1000);
    const intervals: Array<[number, string, string]> = [
      [31536000, "year", "年"],
      [2592000, "month", "個月"],
      [604800, "week", "週"],
      [86400, "day", "天"],
      [3600, "hour", "小時"],
      [60, "minute", "分鐘"],
    ];
    for (const [secs, enUnit, zhUnit] of intervals) {
      const count = Math.floor(seconds / secs);
      if (count >= 1) {
        return {
          en: `${count} ${enUnit}${count > 1 ? "s" : ""} ago`,
          zh: `${count} ${zhUnit}前`,
        };
      }
    }
    return { en: "just now", zh: "剛剛" };
  }

  function getStatus(issue: GitHubIssue): { key: string; en: string; zh: string; cssClass: string } {
    const labelNames = issue.labels.map((l) => l.name.toLowerCase());
    if (labelNames.includes("wontfix") || labelNames.includes("won't fix")) {
      return { key: "declined", en: "Declined", zh: "已婉拒", cssClass: "status-declined" };
    }
    if (issue.state === "closed") {
      return { key: "shipped", en: "Shipped", zh: "已上線", cssClass: "status-shipped" };
    }
    if (labelNames.includes("in-progress") || labelNames.includes("in progress")) {
      return { key: "in-progress", en: "In Progress", zh: "開發中", cssClass: "status-in-progress" };
    }
    return { key: "open", en: "Open", zh: "許願中", cssClass: "status-open" };
  }

  // --- Cache ---

  function getCache(): CacheData | null {
    try {
      const raw = sessionStorage.getItem(CACHE_KEY);
      if (!raw) return null;
      const data: CacheData = JSON.parse(raw);
      if (Date.now() - data.timestamp > CACHE_TTL) return null;
      return data;
    } catch {
      return null;
    }
  }

  function setCache(issues: GitHubIssue[]) {
    try {
      sessionStorage.setItem(CACHE_KEY, JSON.stringify({ timestamp: Date.now(), issues }));
    } catch {
      // sessionStorage full or unavailable
    }
  }

  // --- Fetch ---

  async function fetchIssues(): Promise<GitHubIssue[]> {
    const params = new URLSearchParams({
      labels: "wishlist",
      state: "all",
      per_page: "50",
      sort: "reactions-+1",
      direction: "desc",
    });
    const res = await fetch(`${API_URL}?${params}`, {
      headers: { Accept: "application/vnd.github.v3+json" },
    });
    if (!res.ok) throw new Error(`GitHub API ${res.status}`);
    return res.json();
  }

  // --- Render ---

  function createCard(issue: GitHubIssue): HTMLElement {
    const status = getStatus(issue);
    const votes = issue.reactions["+1"] || 0;
    const ago = timeAgo(issue.created_at);
    const bodyPreview = issue.body ? stripMarkdown(issue.body).slice(0, 120) : "";
    const displayTitle = issue.title.replace(/^\[Wishlist\]\s*/i, "");

    const card = document.createElement("a");
    card.href = issue.html_url;
    card.target = "_blank";
    card.rel = "noopener noreferrer";
    card.className = "wishlist-card feature-card rounded-2xl p-6 block";
    card.dataset.status = status.key;
    card.style.cssText = "background: var(--brand-card); border: 1px solid var(--brand-border); text-decoration: none; color: inherit;";

    // Vote badge + title row
    const header = document.createElement("div");
    header.className = "flex items-start gap-4";

    const voteBadge = document.createElement("div");
    voteBadge.className = "flex flex-col items-center justify-center shrink-0 w-12 h-12 rounded-xl text-center";
    voteBadge.style.cssText = "background: rgba(251, 191, 36, 0.1); color: var(--brand-gold);";
    const voteIcon = document.createElement("span");
    voteIcon.className = "text-xs";
    voteIcon.textContent = "👍";
    const voteCount = document.createElement("span");
    voteCount.className = "text-sm font-bold";
    voteCount.textContent = String(votes);
    voteBadge.appendChild(voteIcon);
    voteBadge.appendChild(voteCount);

    const content = document.createElement("div");
    content.className = "flex-1 min-w-0";

    const title = document.createElement("h3");
    title.className = "text-sm font-semibold mb-1 line-clamp-2";
    title.style.color = "var(--brand-foreground)";
    title.textContent = displayTitle;

    content.appendChild(title);

    if (bodyPreview) {
      const desc = document.createElement("p");
      desc.className = "text-xs leading-relaxed mb-3 line-clamp-2";
      desc.style.color = "var(--brand-muted)";
      desc.textContent = bodyPreview.length >= 120 ? bodyPreview + "..." : bodyPreview;
      content.appendChild(desc);
    }

    // Meta row: status pill + user + time
    const meta = document.createElement("div");
    meta.className = "flex items-center gap-2 flex-wrap text-xs";
    meta.style.color = "var(--brand-muted)";

    const pill = document.createElement("span");
    pill.className = `status-pill ${status.cssClass}`;
    const pillEn = document.createElement("span");
    pillEn.className = "lang-en";
    pillEn.textContent = status.en;
    const pillZh = document.createElement("span");
    pillZh.className = "lang-zh";
    pillZh.textContent = status.zh;
    pill.appendChild(pillEn);
    pill.appendChild(pillZh);
    meta.appendChild(pill);

    if (issue.user) {
      const user = document.createElement("span");
      user.textContent = `@${issue.user.login}`;
      meta.appendChild(user);
    }

    const dot = document.createElement("span");
    dot.style.opacity = "0.3";
    dot.textContent = "·";
    meta.appendChild(dot);

    const time = document.createElement("span");
    const timeEn = document.createElement("span");
    timeEn.className = "lang-en";
    timeEn.textContent = ago.en;
    const timeZh = document.createElement("span");
    timeZh.className = "lang-zh";
    timeZh.textContent = ago.zh;
    time.appendChild(timeEn);
    time.appendChild(timeZh);
    meta.appendChild(time);

    if (issue.comments > 0) {
      const dot2 = document.createElement("span");
      dot2.style.opacity = "0.3";
      dot2.textContent = "·";
      meta.appendChild(dot2);

      const comments = document.createElement("span");
      const commEn = document.createElement("span");
      commEn.className = "lang-en";
      commEn.textContent = `${issue.comments} comment${issue.comments > 1 ? "s" : ""}`;
      const commZh = document.createElement("span");
      commZh.className = "lang-zh";
      commZh.textContent = `${issue.comments} 則留言`;
      comments.appendChild(commEn);
      comments.appendChild(commZh);
      meta.appendChild(comments);
    }

    content.appendChild(meta);
    header.appendChild(voteBadge);
    header.appendChild(content);
    card.appendChild(header);

    // Apply lang visibility based on current setting
    const currentLang = document.documentElement.getAttribute("data-lang") || "en";
    card.querySelectorAll(".lang-en, .lang-zh").forEach((el) => {
      const isEn = el.classList.contains("lang-en");
      (el as HTMLElement).style.display = (currentLang === "zh" ? !isEn : isEn) ? "" : "none";
    });

    return card;
  }

  function createShippedCard(feature: BuiltInFeature): HTMLElement {
    const card = document.createElement("div");
    card.className = "shipped-card rounded-xl p-4";
    card.dataset.status = "shipped";

    const row = document.createElement("div");
    row.className = "flex items-start gap-3";

    // Icon
    const iconWrap = document.createElement("div");
    iconWrap.className = "shipped-card-icon shrink-0 w-9 h-9 rounded-lg flex items-center justify-center mt-0.5";
    iconWrap.innerHTML = feature.icon;

    // Text content
    const content = document.createElement("div");
    content.className = "flex-1 min-w-0";

    // Title row with inline checkmark
    const titleRow = document.createElement("div");
    titleRow.className = "flex items-center gap-1.5";

    const title = document.createElement("h3");
    title.className = "text-sm font-semibold";
    title.style.color = "var(--brand-foreground)";
    const titleEn = document.createElement("span");
    titleEn.className = "lang-en";
    titleEn.textContent = feature.title;
    const titleZh = document.createElement("span");
    titleZh.className = "lang-zh";
    titleZh.textContent = feature.titleZh;
    title.appendChild(titleEn);
    title.appendChild(titleZh);

    const check = document.createElement("span");
    check.className = "shrink-0";
    check.style.color = "#22c55e";
    check.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`;

    titleRow.appendChild(title);
    titleRow.appendChild(check);

    // Description
    const desc = document.createElement("p");
    desc.className = "text-xs leading-relaxed mt-0.5";
    desc.style.color = "var(--brand-muted)";
    const descEn = document.createElement("span");
    descEn.className = "lang-en";
    descEn.textContent = feature.desc;
    const descZh = document.createElement("span");
    descZh.className = "lang-zh";
    descZh.textContent = feature.descZh;
    desc.appendChild(descEn);
    desc.appendChild(descZh);

    content.appendChild(titleRow);
    content.appendChild(desc);
    row.appendChild(iconWrap);
    row.appendChild(content);
    card.appendChild(row);

    const currentLang = document.documentElement.getAttribute("data-lang") || "en";
    card.querySelectorAll(".lang-en, .lang-zh").forEach((el) => {
      const isEn = el.classList.contains("lang-en");
      (el as HTMLElement).style.display = (currentLang === "zh" ? !isEn : isEn) ? "" : "none";
    });

    return card;
  }

  function getFilteredAndSorted(): GitHubIssue[] {
    let filtered = allIssues;

    if (currentFilter !== "all") {
      filtered = allIssues.filter((issue) => {
        const status = getStatus(issue);
        return status.key === currentFilter;
      });
    }

    if (currentSort === "newest") {
      filtered = [...filtered].sort(
        (a, b) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime()
      );
    }
    // "votes" is already the default sort from the API

    return filtered;
  }

  function renderCards() {
    const grid = document.getElementById("wishlist-grid")!;
    const empty = document.getElementById("wishlist-empty")!;
    const footer = document.getElementById("wishlist-footer")!;

    const issues = getFilteredAndSorted();

    grid.innerHTML = "";

    const hasBuiltIn = currentFilter === "shipped" || currentFilter === "all";

    if (issues.length === 0 && allIssues.length === 0 && !hasBuiltIn) {
      grid.classList.add("hidden");
      empty.classList.remove("hidden");
      footer.classList.add("hidden");
      return;
    }

    if (issues.length === 0 && !hasBuiltIn) {
      // Has issues but none match current filter
      grid.innerHTML = "";
      const noMatch = document.createElement("div");
      noMatch.className = "md:col-span-2 text-center py-12";
      const p = document.createElement("p");
      p.className = "text-sm";
      p.style.color = "var(--brand-muted)";
      const pEn = document.createElement("span");
      pEn.className = "lang-en";
      pEn.textContent = "No requests match this filter.";
      const pZh = document.createElement("span");
      pZh.className = "lang-zh";
      pZh.textContent = "沒有符合此篩選條件的許願。";
      p.appendChild(pEn);
      p.appendChild(pZh);
      noMatch.appendChild(p);

      // Apply current lang
      const currentLang = document.documentElement.getAttribute("data-lang") || "en";
      noMatch.querySelectorAll(".lang-en, .lang-zh").forEach((el) => {
        const isEn = el.classList.contains("lang-en");
        (el as HTMLElement).style.display = (currentLang === "zh" ? !isEn : isEn) ? "" : "none";
      });

      grid.appendChild(noMatch);
      grid.classList.remove("hidden");
      empty.classList.add("hidden");
      footer.classList.remove("hidden");
      return;
    }

    empty.classList.add("hidden");
    grid.classList.remove("hidden");
    footer.classList.remove("hidden");

    // Show built-in shipped features for "shipped" and "all" tabs
    const showShipped = currentFilter === "shipped" || currentFilter === "all";
    if (showShipped) {
      // Use 3-col grid for compact shipped cards
      grid.className = "grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3";
      SHIPPED_FEATURES.forEach((f) => {
        grid.appendChild(createShippedCard(f));
      });
    }

    if (issues.length > 0) {
      if (showShipped && issues.length > 0) {
        // Add a separator + switch back to 2-col for GitHub issues
        const sep = document.createElement("div");
        sep.className = "col-span-full pt-6 pb-2";
        const sepInner = document.createElement("p");
        sepInner.className = "text-xs font-medium tracking-wide uppercase";
        sepInner.style.color = "var(--brand-muted)";
        sepInner.style.opacity = "0.5";
        const sepEn = document.createElement("span");
        sepEn.className = "lang-en";
        sepEn.textContent = "From community";
        const sepZh = document.createElement("span");
        sepZh.className = "lang-zh";
        sepZh.textContent = "來自社群";
        sepInner.appendChild(sepEn);
        sepInner.appendChild(sepZh);
        sep.appendChild(sepInner);
        grid.appendChild(sep);

        const currentLang = document.documentElement.getAttribute("data-lang") || "en";
        sep.querySelectorAll(".lang-en, .lang-zh").forEach((el) => {
          const isEn = el.classList.contains("lang-en");
          (el as HTMLElement).style.display = (currentLang === "zh" ? !isEn : isEn) ? "" : "none";
        });
      }

      issues.forEach((issue) => {
        grid.appendChild(createCard(issue));
      });
    }

    if (!showShipped) {
      // Restore 2-col grid for non-shipped views
      grid.className = "grid grid-cols-1 md:grid-cols-2 gap-4";
    }
  }

  function showError() {
    document.getElementById("wishlist-grid")!.classList.add("hidden");
    document.getElementById("wishlist-empty")!.classList.add("hidden");
    document.getElementById("wishlist-error")!.classList.remove("hidden");
    document.getElementById("wishlist-footer")!.classList.add("hidden");
  }

  // --- Init ---

  async function init() {
    // Render built-in shipped features immediately (no skeleton needed)
    renderCards();

    const cached = getCache();
    if (cached) {
      allIssues = cached.issues;
      renderCards();
      // Still refresh in background
      fetchIssues()
        .then((issues) => {
          allIssues = issues;
          setCache(issues);
          renderCards();
        })
        .catch(() => {});
      return;
    }

    try {
      allIssues = await fetchIssues();
      setCache(allIssues);
      renderCards();
    } catch {
      // Try stale cache
      try {
        const raw = sessionStorage.getItem(CACHE_KEY);
        if (raw) {
          allIssues = JSON.parse(raw).issues;
          renderCards();
          return;
        }
      } catch {}
      // Built-in features are already showing, only show error if on a non-shipped tab
      if (currentFilter !== "shipped") {
        showError();
      }
    }
  }

  // --- Event listeners ---

  document.querySelectorAll<HTMLButtonElement>(".wishlist-tab").forEach((tab) => {
    tab.addEventListener("click", () => {
      document.querySelectorAll(".wishlist-tab").forEach((t) => t.classList.remove("active"));
      tab.classList.add("active");
      currentFilter = tab.dataset.filter!;
      renderCards();
    });
  });

  document.querySelectorAll<HTMLButtonElement>(".wishlist-sort").forEach((btn) => {
    btn.addEventListener("click", () => {
      document.querySelectorAll(".wishlist-sort").forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");
      currentSort = btn.dataset.sort!;
      if (currentSort === "votes") {
        allIssues.sort((a, b) => (b.reactions["+1"] || 0) - (a.reactions["+1"] || 0));
      }
      renderCards();
    });
  });

  document.getElementById("wishlist-retry")?.addEventListener("click", () => {
    document.getElementById("wishlist-error")!.classList.add("hidden");
    document.getElementById("wishlist-grid")!.classList.remove("hidden");
    // Re-show skeletons
    const grid = document.getElementById("wishlist-grid")!;
    grid.innerHTML = "";
    for (let i = 0; i < 4; i++) {
      const skel = document.createElement("div");
      skel.className = "wishlist-skeleton rounded-2xl p-6";
      skel.style.cssText = "background: var(--brand-card); border: 1px solid var(--brand-border);";
      skel.innerHTML = `<div class="flex items-start gap-4"><div class="skeleton-pulse w-12 h-12 rounded-xl shrink-0"></div><div class="flex-1 space-y-3"><div class="skeleton-pulse h-4 rounded w-3/4"></div><div class="skeleton-pulse h-3 rounded w-full"></div><div class="skeleton-pulse h-3 rounded w-1/2"></div></div></div>`;
      grid.appendChild(skel);
    }
    init();
  });

  init();
</script>
