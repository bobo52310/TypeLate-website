---
import { Image } from "astro:assets";
import NotchHudDemo from "./NotchHudDemo.astro";
import { DOWNLOAD_URLS, GITHUB_URL, GITHUB_OWNER, GITHUB_REPO } from "../config/site";
import logoSrc from "../assets/logo-typelate.png";

const DOWNLOAD_MAC = DOWNLOAD_URLS.macArm64;
const DOWNLOAD_MAC_INTEL = DOWNLOAD_URLS.macIntel;
const DOWNLOAD_ANDROID = DOWNLOAD_URLS.android;
const DOWNLOAD_WIN = DOWNLOAD_URLS.windows;
const WISHLIST_IOS = DOWNLOAD_URLS.iosWishlist;

// Fetch GitHub stats at build time
let starCount = "";
let downloadCount = "";
try {
  const [repoRes, releasesRes] = await Promise.all([
    fetch(`https://api.github.com/repos/${GITHUB_OWNER}/${GITHUB_REPO}`, {
      headers: { "Accept": "application/vnd.github.v3+json" },
    }),
    fetch(`https://api.github.com/repos/${GITHUB_OWNER}/${GITHUB_REPO}/releases?per_page=10`, {
      headers: { "Accept": "application/vnd.github.v3+json" },
    }),
  ]);

  if (repoRes.ok) {
    const data = await repoRes.json();
    const count = data.stargazers_count as number;
    starCount = count >= 1000 ? `${(count / 1000).toFixed(1)}k` : String(count);
  }

  if (releasesRes.ok) {
    const releases = await releasesRes.json() as Array<{ assets: Array<{ download_count: number }> }>;
    const total = releases.reduce(
      (sum, r) => sum + r.assets.reduce((s, a) => s + a.download_count, 0),
      0
    );
    if (total > 0) {
      downloadCount = total >= 1000 ? `${(total / 1000).toFixed(1)}k` : String(total);
    }
  }
} catch {
  // Silently fail — badges just won't show
}
---

<section
  class="relative min-h-screen flex flex-col items-center justify-center px-6 pt-20 pb-16 overflow-hidden"
>
  <!-- Background orbs -->
  <div
    class="absolute top-[-8rem] right-[-8rem] w-64 h-64 rounded-full opacity-60 pointer-events-none"
    style="background: rgba(251, 191, 36, 0.06); filter: blur(80px);"
  >
  </div>
  <div
    class="absolute bottom-[-6rem] left-[-6rem] w-48 h-48 rounded-full opacity-60 pointer-events-none"
    style="background: rgba(251, 191, 36, 0.04); filter: blur(60px);"
  >
  </div>

  <!-- Badges -->
  <div class="fade-in flex flex-wrap items-center justify-center gap-2 mb-8">
    <span
      class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-medium tracking-wide"
      style="background: rgba(251, 191, 36, 0.1); color: var(--brand-gold); border: 1px solid rgba(251, 191, 36, 0.2);"
    >
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path>
        <path d="M9 18c-4.51 2-5-2-7-2"></path>
      </svg>
      100% Free &middot; Open Source &middot; MIT Licensed
    </span>
    <span
      class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-medium tracking-wide"
      style="background: rgba(99, 102, 241, 0.08); color: #818cf8; border: 1px solid rgba(99, 102, 241, 0.2);"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
      </svg>
      <span class="lang-en">Built by the community</span><span class="lang-zh">由社群共同打造</span>
    </span>
  </div>

  <!-- Logo -->
  <div class="fade-in mb-8">
    <Image
      src={logoSrc}
      alt="TypeLate"
      width={128}
      height={128}
      class="logo-glow"
      loading="eager"
      fetchpriority="high"
    />
  </div>

  <!-- Headlines -->
  <div class="fade-in text-center max-w-3xl mb-6">
    <h1
      class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight leading-tight mb-3"
    >
      <span class="lang-en">Too late to type — just speak.</span>
      <span class="lang-zh">打字太累？用說的才對味！</span>
    </h1>
  </div>

  <!-- Rotating slogans -->
  <div class="fade-in text-center max-w-3xl w-full mb-6">
    <p class="slogan-rotator h-10 relative overflow-hidden w-full">
      <span class="slogan-item absolute inset-x-0 transition-all duration-500" data-slogan="0">
        <span class="lang-en">Type is Late — voice is the future</span>
        <span class="lang-zh">Type is Late — 打字已過時，語音才對味</span>
      </span>
      <span class="slogan-item absolute inset-x-0 transition-all duration-500 opacity-0 translate-y-4" data-slogan="2">
        <span class="lang-en">Tired of typing? Speaking just hits different</span>
        <span class="lang-zh">打字太累，用說的才對味</span>
      </span>
      <span class="slogan-item absolute inset-x-0 transition-all duration-500 opacity-0 translate-y-4" data-slogan="3">
        <span class="lang-en">Ditch the keyboard, double the output — try TypeLate</span>
        <span class="lang-zh">手打太累，嘴砲輸出加倍 — 快用 TypeLate</span>
      </span>
    </p>
  </div>

  <!-- Subtitle -->
  <div class="fade-in text-center max-w-2xl mb-4">
    <p class="text-base sm:text-lg leading-relaxed" style="color: var(--brand-muted);">
      <span class="lang-en">Press a hotkey, speak naturally, release. Your voice becomes polished text
      in under 3 seconds — right where you type.</span>
      <span class="lang-zh">開口說，AI 潤稿，你的詞彙最對味。</span>
    </p>
  </div>

  <!-- CTA Buttons -->
  <div class="fade-in flex flex-col sm:flex-row items-center gap-4 mb-8">
    <a
      id="hero-download-btn"
      href={DOWNLOAD_MAC}
      data-mac={DOWNLOAD_MAC}
      data-windows={DOWNLOAD_WIN}
      data-android={DOWNLOAD_ANDROID}
      class="inline-flex items-center gap-2 px-7 py-3 rounded-xl text-base font-semibold transition-all duration-200 hover:scale-105"
      style="background: linear-gradient(135deg, #fbbf24, #f59e0b); color: #0f172a;"
    >
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
        <polyline points="7 10 12 15 17 10"></polyline>
        <line x1="12" y1="15" x2="12" y2="3"></line>
      </svg>
      <span id="hero-download-label-en" class="lang-en">Download for macOS</span>
      <span id="hero-download-label-zh" class="lang-zh">下載 macOS 版</span>
    </a>
    <a
      href={GITHUB_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 px-7 py-3 rounded-xl text-base font-semibold transition-all duration-200 hover:scale-105"
      style="border: 1px solid var(--brand-border); color: var(--brand-foreground);"
    >
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="currentColor"
        class="opacity-80"
      >
        <path
          d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
        ></path>
      </svg>
      <span class="lang-en">View on GitHub</span><span class="lang-zh">在 GitHub 查看</span>
      {starCount && (
        <span
          class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium"
          style="background: rgba(251, 191, 36, 0.12); color: var(--brand-gold);"
        >
          <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
          {starCount}
        </span>
      )}
    </a>
  </div>

  <!-- Community nudge -->
  <p class="fade-in text-xs mb-6" style="color: var(--brand-muted); opacity: 0.7;">
    <span class="lang-en">Open source &amp; growing — <a href="https://github.com/bobo52310/TypeLate" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 hover:opacity-100 transition-opacity" style="color: #818cf8;">join us on GitHub</a></span>
    <span class="lang-zh">開源持續成長中 — <a href="https://github.com/bobo52310/TypeLate" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 hover:opacity-100 transition-opacity" style="color: #818cf8;">一起在 GitHub 打造</a></span>
  </p>

  <!-- Platform links -->
  <div class="fade-in flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-xs" style="color: var(--brand-muted);">
    <a href={DOWNLOAD_MAC} class="hover:text-[var(--brand-gold)] transition-colors">
      macOS (Apple Silicon)
    </a>
    <span class="opacity-30">|</span>
    <a href={DOWNLOAD_MAC_INTEL} class="hover:text-[var(--brand-gold)] transition-colors">
      macOS (Intel)
    </a>
    <span class="opacity-30">|</span>
    <a href={DOWNLOAD_ANDROID} class="hover:text-[var(--brand-gold)] transition-colors">
      Android
    </a>
    <span class="opacity-30">|</span>
    <a href={DOWNLOAD_WIN} class="hover:text-[var(--brand-gold)] transition-colors">
      Windows
    </a>
    <span class="opacity-30">|</span>
    <a href={WISHLIST_IOS} target="_blank" rel="noopener noreferrer" class="hover:text-[var(--brand-gold)] transition-colors opacity-60 hover:opacity-100">
      iOS <span class="text-[10px]" style="color: var(--brand-gold);">Coming Soon</span>
    </a>
  </div>

  <!-- Notch HUD Demo -->
  <div class="fade-in mt-16">
    <NotchHudDemo />
  </div>
</section>

<style>
  .slogan-rotator {
    font-size: 0.95rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--brand-gold);
    opacity: 0.75;
  }
  .slogan-item {
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  .slogan-item.active {
    opacity: 1;
    transform: translateY(0);
  }
  .slogan-item.exit {
    opacity: 0;
    transform: translateY(-1rem);
  }
</style>

<script>
  // OS auto-detection for download button
  const btn = document.getElementById('hero-download-btn') as HTMLAnchorElement | null;
  if (btn) {
    const ua = navigator.userAgent.toLowerCase();
    const labelEn = document.getElementById('hero-download-label-en');
    const labelZh = document.getElementById('hero-download-label-zh');

    if (ua.includes('win')) {
      btn.href = btn.dataset.windows!;
      if (labelEn) labelEn.textContent = 'Download for Windows';
      if (labelZh) labelZh.textContent = '下載 Windows 版';
    } else if (ua.includes('android')) {
      btn.href = btn.dataset.android!;
      if (labelEn) labelEn.textContent = 'Download for Android';
      if (labelZh) labelZh.textContent = '下載 Android 版';
    }
    // macOS is the default — no change needed
  }

  const items = document.querySelectorAll<HTMLElement>('.slogan-item');
  if (items.length > 0) {
    let current = 0;
    items[0].classList.add('active');

    setInterval(() => {
      const prev = current;
      current = (current + 1) % items.length;

      items[prev].classList.remove('active');
      items[prev].classList.add('exit');

      setTimeout(() => {
        items[prev].classList.remove('exit');
        // Reset to below position for next entrance
        items[prev].style.opacity = '0';
        items[prev].style.transform = 'translateY(1rem)';
      }, 500);

      // New item enters from below
      items[current].style.opacity = '0';
      items[current].style.transform = 'translateY(1rem)';
      // Force reflow
      void items[current].offsetHeight;
      items[current].classList.add('active');
      items[current].style.opacity = '';
      items[current].style.transform = '';
    }, 3000);
  }
</script>
