---
import { GITHUB_URL, DOWNLOAD_URLS } from "../config/site";
import SiteSearch from "./SiteSearch.astro";

const DOWNLOAD_URL = DOWNLOAD_URLS.macArm64;
---

<nav
  id="main-nav"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  style="background: transparent;"
>
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <!-- Left: Logo + Name -->
    <a href="/" class="flex items-center gap-3 group">
      <img
        src="/assets/logo-typelate.png"
        alt="TypeLate"
        width="32"
        height="32"
        class="rounded-lg"
      />
      <span class="text-gradient-gold font-bold text-lg tracking-tight">
        TypeLate
      </span>
    </a>

    <!-- Center: Section links (desktop only) -->
    <div id="nav-links" class="hidden lg:flex items-center gap-6 text-sm" style="color: var(--brand-muted);">
      <a href="/#features" data-nav-section="features" class="nav-section-link hover:text-[var(--brand-foreground)] transition-colors">
        <span class="lang-en">Features</span><span class="lang-zh">功能</span>
      </a>
      <a href="/#how-it-works" data-nav-section="how-it-works" class="nav-section-link hover:text-[var(--brand-foreground)] transition-colors">
        <span class="lang-en">How It Works</span><span class="lang-zh">使用方式</span>
      </a>
      <a href="/#comparison" data-nav-section="comparison" class="nav-section-link hover:text-[var(--brand-foreground)] transition-colors">
        <span class="lang-en">Compare</span><span class="lang-zh">比較</span>
      </a>
      <a href="/#faq" data-nav-section="faq" class="nav-section-link hover:text-[var(--brand-foreground)] transition-colors">
        FAQ
      </a>
      <a href="/docs" class="nav-static-link hover:text-[var(--brand-foreground)] transition-colors">
        <span class="lang-en">Docs</span><span class="lang-zh">文件</span>
      </a>
    </div>

    <!-- Right: Desktop actions -->
    <div class="flex items-center gap-4">
      <a
        href={GITHUB_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="text-[var(--brand-muted)] hover:text-[var(--brand-foreground)] transition-colors hidden sm:flex items-center gap-2 text-sm"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="opacity-70">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path>
        </svg>
        <span>GitHub</span>
      </a>
      <a
        href="/wishlist"
        class="text-[var(--brand-muted)] hover:text-[var(--brand-foreground)] transition-colors hidden sm:flex items-center gap-1.5 text-sm"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="opacity-70">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
        <span class="lang-en">Wishlist</span><span class="lang-zh">許願池</span>
      </a>
      <button
        type="button"
        class="site-search-trigger hidden sm:inline-flex items-center gap-1.5 px-2.5 py-1.5 rounded-md text-xs transition-colors"
        style="border: 1px solid var(--brand-border); color: var(--brand-muted); background: transparent;"
        aria-label="Open site search"
        aria-haspopup="dialog"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <span class="hidden lg:inline">
          <span class="lang-en">Search</span><span class="lang-zh">搜尋</span>
        </span>
        <kbd class="hidden lg:inline-flex items-center px-1 ml-1 text-[10px] font-mono" style="border: 1px solid var(--brand-border); border-radius: 3px;">⌘K</kbd>
      </button>
      <div id="lang-toggle" class="hidden sm:flex items-center rounded-lg overflow-hidden text-xs" style="border: 1px solid var(--brand-border);">
        <button data-lang-btn="en" class="px-2.5 py-1.5 font-medium transition-colors" style="background: rgba(251, 191, 36, 0.15); color: var(--brand-gold);">EN</button>
        <button data-lang-btn="zh" class="px-2.5 py-1.5 font-medium transition-colors" style="color: var(--brand-muted);">中文</button>
      </div>
      <a
        id="nav-download-btn"
        href={DOWNLOAD_URL}
        class="hidden sm:inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-semibold transition-all duration-300 hover:scale-105 opacity-0 translate-y-1 pointer-events-none"
        style="background: linear-gradient(135deg, #fbbf24, #f59e0b); color: #0f172a;"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
          <polyline points="7 10 12 15 17 10"></polyline>
          <line x1="12" y1="15" x2="12" y2="3"></line>
        </svg>
        <span class="lang-en">Download</span><span class="lang-zh">下載</span>
      </a>

      <!-- Mobile: Search + Download + Hamburger -->
      <button
        type="button"
        class="site-search-trigger sm:hidden flex items-center justify-center w-9 h-9 rounded-lg transition-colors"
        style="border: 1px solid var(--brand-border); color: var(--brand-muted); background: transparent;"
        aria-label="Open site search"
        aria-haspopup="dialog"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
      </button>
      <a
        href={DOWNLOAD_URL}
        class="sm:hidden inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-semibold"
        style="background: linear-gradient(135deg, #fbbf24, #f59e0b); color: #0f172a;"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        <span class="lang-en">Get</span><span class="lang-zh">下載</span>
      </a>
      <button
        id="mobile-menu-btn"
        class="sm:hidden flex items-center justify-center w-10 h-10 rounded-lg transition-colors"
        style="color: var(--brand-muted);"
        aria-label="Open menu"
        aria-expanded="false"
      >
        <svg id="menu-icon-open" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/>
        </svg>
        <svg id="menu-icon-close" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
          <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile dropdown menu (animated via max-height) -->
  <div
    id="mobile-menu"
    class="sm:hidden overflow-hidden transition-[max-height] duration-300 ease-in-out max-h-0"
    style="background: rgba(15, 23, 42, 0.98); backdrop-filter: blur(20px); border-bottom: 1px solid var(--brand-border);"
  >
    <div class="max-w-6xl mx-auto px-6 py-4 space-y-1">
      <!-- Section links -->
      <a href="/#features" class="mobile-menu-link block px-3 py-2.5 rounded-lg text-sm transition-colors" style="color: var(--brand-muted);">
        <span class="lang-en">Features</span><span class="lang-zh">功能</span>
      </a>
      <a href="/#how-it-works" class="mobile-menu-link block px-3 py-2.5 rounded-lg text-sm transition-colors" style="color: var(--brand-muted);">
        <span class="lang-en">How It Works</span><span class="lang-zh">使用方式</span>
      </a>
      <a href="/#comparison" class="mobile-menu-link block px-3 py-2.5 rounded-lg text-sm transition-colors" style="color: var(--brand-muted);">
        <span class="lang-en">Compare</span><span class="lang-zh">比較</span>
      </a>
      <a href="/#faq" class="mobile-menu-link block px-3 py-2.5 rounded-lg text-sm transition-colors" style="color: var(--brand-muted);">
        FAQ
      </a>
      <a href="/docs" class="mobile-menu-link block px-3 py-2.5 rounded-lg text-sm transition-colors" style="color: var(--brand-muted);">
        <span class="lang-en">Docs</span><span class="lang-zh">文件</span>
      </a>

      <div class="my-2" style="border-top: 1px solid var(--brand-border);"></div>

      <!-- External links -->
      <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer" class="mobile-menu-link flex items-center gap-2 px-3 py-2.5 rounded-lg text-sm transition-colors" style="color: var(--brand-muted);">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="opacity-70">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path>
        </svg>
        GitHub
      </a>
      <a href="/wishlist" class="mobile-menu-link flex items-center gap-2 px-3 py-2.5 rounded-lg text-sm transition-colors" style="color: var(--brand-muted);">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="opacity-70">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
        <span class="lang-en">Wishlist</span><span class="lang-zh">許願池</span>
      </a>

      <div class="my-2" style="border-top: 1px solid var(--brand-border);"></div>

      <!-- Language toggle -->
      <div class="flex items-center gap-2 px-3 py-2">
        <span class="text-xs" style="color: var(--brand-muted);">
          <span class="lang-en">Language</span><span class="lang-zh">語言</span>
        </span>
        <div class="flex items-center rounded-lg overflow-hidden text-xs" style="border: 1px solid var(--brand-border);">
          <button data-lang-btn="en" class="px-2.5 py-1.5 font-medium transition-colors" style="background: rgba(251, 191, 36, 0.15); color: var(--brand-gold);">EN</button>
          <button data-lang-btn="zh" class="px-2.5 py-1.5 font-medium transition-colors" style="color: var(--brand-muted);">中文</button>
        </div>
      </div>

      <!-- Download CTA -->
      <a
        href={DOWNLOAD_URL}
        class="flex items-center justify-center gap-2 px-4 py-3 rounded-xl text-sm font-semibold transition-all duration-200 mt-2"
        style="background: linear-gradient(135deg, #fbbf24, #f59e0b); color: #0f172a;"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
          <polyline points="7 10 12 15 17 10"></polyline>
          <line x1="12" y1="15" x2="12" y2="3"></line>
        </svg>
        <span class="lang-en">Download for Free</span><span class="lang-zh">免費下載</span>
      </a>
    </div>
  </div>
</nav>

<SiteSearch />

<style>
  .mobile-menu-link:hover,
  .mobile-menu-link:active {
    background: rgba(251, 191, 36, 0.05);
    color: var(--brand-foreground);
  }
</style>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  function closeMenu() {
    if (!menu || !iconOpen || !iconClose || !menuBtn) return;
    menu.style.maxHeight = '0';
    iconOpen.classList.remove('hidden');
    iconClose.classList.add('hidden');
    menuBtn.setAttribute('aria-expanded', 'false');
  }

  if (menuBtn && menu && iconOpen && iconClose) {
    menuBtn.addEventListener('click', () => {
      const isOpen = menuBtn.getAttribute('aria-expanded') === 'true';
      if (isOpen) {
        closeMenu();
      } else {
        menu.style.maxHeight = menu.scrollHeight + 'px';
        iconOpen.classList.add('hidden');
        iconClose.classList.remove('hidden');
        menuBtn.setAttribute('aria-expanded', 'true');
      }
    });

    // Close menu when clicking a link
    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', closeMenu);
    });
  }

  // Highlight static nav links when on their route (e.g. /docs/*)
  if (window.location.pathname.startsWith('/docs')) {
    document.querySelectorAll<HTMLAnchorElement>('.nav-static-link').forEach((a) => {
      if (a.getAttribute('href') === '/docs') {
        a.classList.add('is-current');
      }
    });
    document.querySelectorAll<HTMLAnchorElement>('.mobile-menu-link').forEach((a) => {
      if (a.getAttribute('href') === '/docs') {
        a.style.color = 'var(--brand-gold)';
      }
    });
  }
</script>
