---
import { GITHUB_OWNER } from "../config/site";

const developer = {
  name: "Bobo Chen",
  role: "Creator of TypeLate",
  roleZh: "TypeLate 創作者",
  bio: "Full-stack developer passionate about making voice technology accessible to everyone. Built TypeLate to solve my own frustration with typing long messages — now sharing it with the world as open source.",
  bioZh: "全端工程師，致力於讓語音科技更容易被每個人使用。因為自己打字打到厭煩而打造了 TypeLate — 現在以開源方式與全世界分享。",
  github: `https://github.com/${GITHUB_OWNER}`,
  avatar: `https://github.com/${GITHUB_OWNER}.png?size=128`,
};
---

<section id="developer" class="py-24 px-6" style="background: rgba(30, 41, 59, 0.3);">
  <div class="max-w-3xl mx-auto">
    <!-- Section title -->
    <div class="fade-in text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-2">
        <span class="lang-en">Meet the Developer</span>
        <span class="lang-zh">認識開發者</span>
      </h2>
    </div>

    <!-- Developer card -->
    <div
      class="fade-in flex flex-col sm:flex-row items-center sm:items-start gap-8 rounded-2xl p-8"
      style="background: var(--brand-card); border: 1px solid var(--brand-border);"
    >
      <!-- Avatar -->
      <img
        src={developer.avatar}
        alt={developer.name}
        width="112"
        height="112"
        class="w-24 h-24 sm:w-28 sm:h-28 rounded-2xl flex-shrink-0 object-cover"
        style="border: 2px solid rgba(251, 191, 36, 0.2);"
        loading="lazy"
      />

      <!-- Text -->
      <div class="text-center sm:text-left">
        <h3 class="text-xl font-bold mb-1">{developer.name}</h3>
        <p class="text-sm mb-3" style="color: var(--brand-gold);">
          <span class="lang-en">{developer.role}</span>
          <span class="lang-zh">{developer.roleZh}</span>
        </p>
        <p class="text-sm leading-relaxed mb-4" style="color: var(--brand-muted);">
          <span class="lang-en">{developer.bio}</span>
          <span class="lang-zh">{developer.bioZh}</span>
        </p>

        <!-- Social links -->
        <div class="flex items-center gap-4 justify-center sm:justify-start">
          <a
            href={developer.github}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm transition-colors duration-200 text-[var(--brand-muted)] hover:text-[var(--brand-foreground)]"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
              <path d="M9 18c-4.51 2-5-2-7-2" />
            </svg>
            GitHub
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
