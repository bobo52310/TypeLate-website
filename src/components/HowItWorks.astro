---
const steps = [
  {
    num: "1",
    title: "Hold Hotkey",
    titleZh: "按住快捷鍵",
    desc: "Press Fn (or your custom hotkey) in any application.",
    descZh: "在任何應用程式中按住 Fn 鍵",
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M6 8h.01M10 8h.01M14 8h.01M18 8h.01M8 12h8M6 16h12"/></svg>`,
  },
  {
    num: "2",
    title: "Speak Naturally",
    titleZh: "自然說話",
    desc: "Talk as you normally would. No need to articulate perfectly.",
    descZh: "用平常說話的方式，不用字正腔圓",
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="22"/></svg>`,
  },
  {
    num: "3",
    title: "Text Appears",
    titleZh: "文字出現",
    desc: "AI transcribes, enhances, and pastes at your cursor in under 3 seconds.",
    descZh: "AI 轉錄、潤飾、貼上，3 秒完成",
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.375 2.625a1 1 0 0 1 3 3l-9.013 9.014a2 2 0 0 1-.853.505l-2.873.84a.5.5 0 0 1-.62-.62l.84-2.873a2 2 0 0 1 .506-.852z"/></svg>`,
  },
];
---

<section class="py-24 px-6">
  <div class="max-w-5xl mx-auto">
    <!-- Section title -->
    <div class="fade-in text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-2">
        How It Works
      </h2>
      <p class="text-sm" style="color: var(--brand-gold); opacity: 0.7;">
        三步完成
      </p>
    </div>

    <!-- Steps -->
    <div class="fade-in grid grid-cols-1 md:grid-cols-3 gap-8 relative">
      <!-- Connector line (desktop) -->
      <div
        class="hidden md:block absolute top-12 left-[16.6%] right-[16.6%] h-px"
        style="background: linear-gradient(90deg, transparent, var(--brand-border), var(--brand-border), transparent);"
      >
      </div>

      {
        steps.map((step) => (
          <div class="fade-in-child flex flex-col items-center text-center relative">
            {/* Step number */}
            <div
              class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold mb-5 relative z-10"
              style="background: linear-gradient(135deg, #fbbf24, #f59e0b); color: #0f172a;"
            >
              {step.num}
            </div>

            {/* Icon */}
            <div
              class="w-16 h-16 rounded-2xl flex items-center justify-center mb-5"
              style="background: rgba(251, 191, 36, 0.08); color: var(--brand-gold);"
            >
              <Fragment set:html={step.icon} />
            </div>

            {/* Text */}
            <h3 class="text-lg font-semibold mb-1">{step.title}</h3>
            <p
              class="text-xs mb-2"
              style="color: var(--brand-gold); opacity: 0.7;"
            >
              {step.titleZh}
            </p>
            <p class="text-sm leading-relaxed" style="color: var(--brand-muted);">
              {step.desc}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
