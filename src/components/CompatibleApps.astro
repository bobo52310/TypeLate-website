---

<section id="compatible-apps" class="py-24 px-6">
  <div class="max-w-5xl mx-auto">
    <!-- Section title -->
    <div class="fade-in text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-2">
        <span class="lang-en">Works Everywhere You Type</span>
        <span class="lang-zh">在你打字的地方都能用</span>
      </h2>
      <p class="text-sm mt-3" style="color: var(--brand-muted);">
        <span class="lang-en">System-wide integration. No app-specific plugins needed.</span>
        <span class="lang-zh">系統層級整合，不需要任何外掛。</span>
      </p>
    </div>

    <!-- App grid -->
    <div class="fade-in grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 gap-4">
      {
        apps.map((app) => (
          <div class="fade-in-child flex flex-col items-center gap-2 p-4 rounded-xl transition-all duration-200 hover:bg-[rgba(251,191,36,0.05)]">
            <div
              class="w-12 h-12 rounded-xl flex items-center justify-center"
              style="background: rgba(251, 191, 36, 0.08); color: var(--brand-gold);"
            >
              <Fragment set:html={app.icon} />
            </div>
            <span class="text-xs" style="color: var(--brand-muted);">
              {app.name}
            </span>
          </div>
        ))
      }
    </div>

    <!-- Bottom note -->
    <p class="fade-in text-center text-sm mt-8" style="color: var(--brand-muted);">
      <span class="lang-en">
        TypeLate works at the OS level — if you can type there, you can speak there.
      </span>
      <span class="lang-zh">
        TypeLate 在作業系統層級運作 — 能打字的地方，就能用說的。
      </span>
    </p>
  </div>
</section>
