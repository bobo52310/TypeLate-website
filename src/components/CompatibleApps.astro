---
const apps = [
  { name: "Mail", icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>` },
  { name: "Slack", icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="13" y="2" width="3" height="8" rx="1.5"/><rect x="8" y="14" width="3" height="8" rx="1.5"/><rect x="14" y="13" width="8" height="3" rx="1.5"/><rect x="2" y="8" width="8" height="3" rx="1.5"/></svg>` },
  { name: "Notion", icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h6l10 12V4h-4"/><path d="M4 20V8l10 12h6"/></svg>` },
  { name: "VS Code", icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m16 3 5 3v12l-5 3-11-8.5L2 15V9l3-1.5L16 16V3z"/></svg>` },
  { name: "iMessage", icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>` },
  { name: "Docs", icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><line x1="8" y1="13" x2="16" y2="13"/><line x1="8" y1="17" x2="16" y2="17"/></svg>` },
  { name: "Chrome", icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4"/><line x1="21.17" y1="8" x2="12" y2="8"/><line x1="3.95" y1="6.06" x2="8.54" y2="14"/><line x1="10.88" y1="21.94" x2="15.46" y2="14"/></svg>` },
  { name: "Terminal", icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>` },
  { name: "Figma", icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 5.5A3.5 3.5 0 0 1 8.5 2H12v7H8.5A3.5 3.5 0 0 1 5 5.5z"/><path d="M12 2h3.5a3.5 3.5 0 0 1 0 7H12V2z"/><path d="M12 12.5a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z"/><path d="M5 19.5A3.5 3.5 0 0 1 8.5 16H12v3.5a3.5 3.5 0 1 1-7 0z"/><path d="M5 12.5A3.5 3.5 0 0 1 8.5 9H12v7H8.5A3.5 3.5 0 0 1 5 12.5z"/></svg>` },
  { name: "Linear", icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>` },
  { name: "Discord", icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="8.5" cy="13" r="1.5"/><circle cx="15.5" cy="13" r="1.5"/><path d="M7 3.5C10 2.5 14 2.5 17 3.5"/><path d="M7 20.5C10 21.5 14 21.5 17 20.5"/><path d="M4.5 7C3 10 3 14 4.5 17L6 20.5"/><path d="M19.5 7C21 10 21 14 19.5 17L18 20.5"/></svg>` },
  { name: "…any app", nameZh: "…任何", icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>` },
];
---

<section id="compatible-apps" class="apps-v2">
  <div class="apps-container">
    <div class="apps-split">
      <div class="apps-copy fade-in">
        <div class="apps-kicker">
          <span class="lang-en">03 — Everywhere</span>
          <span class="lang-zh">03 — 隨處可用</span>
        </div>
        <h2 class="apps-h2">
          <span class="lang-en">Wherever you type,<br />you can speak.</span>
          <span class="lang-zh">能打字的地方，<br />都能用說的。</span>
        </h2>
        <p class="apps-desc">
          <span class="lang-en">TypeLate works at the OS level. No extensions, no browser plugins. Anywhere you have a cursor, you can speak.</span>
          <span class="lang-zh">TypeLate 運作在作業系統層級，沒有任何外掛、沒有瀏覽器擴充。有游標的地方，就能說話。</span>
        </p>
      </div>

      <div class="apps-grid fade-in">
        {apps.map((app) => (
          <div class="apps-tile fade-in-child">
            <div class="apps-tile-icon">
              <Fragment set:html={app.icon} />
            </div>
            <div class="apps-tile-name">
              <span class="lang-en">{app.name}</span>
              <span class="lang-zh">{app.nameZh || app.name}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .apps-v2 {
    padding: 90px 24px;
    border-top: 1px solid rgba(51, 65, 85, 0.5);
    background: var(--brand-bg);
  }
  .apps-container { max-width: 1080px; margin: 0 auto; }
  .apps-split {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 60px;
    align-items: center;
  }
  @media (max-width: 800px) {
    .apps-split { grid-template-columns: 1fr; gap: 40px; }
  }

  .apps-kicker {
    font-size: 11px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--brand-gold);
    font-weight: 600;
    margin-bottom: 14px;
  }
  .apps-h2 {
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin: 0 0 18px 0;
    color: var(--brand-foreground);
  }
  .apps-desc {
    font-size: 15px;
    line-height: 1.7;
    color: var(--brand-muted);
    margin: 0;
  }

  .apps-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
  }
  @media (max-width: 500px) {
    .apps-grid { grid-template-columns: repeat(3, 1fr); }
  }
  .apps-tile {
    aspect-ratio: 1;
    border-radius: 10px;
    background: var(--brand-card);
    border: 1px solid rgba(51, 65, 85, 0.5);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    transition: border-color 0.2s ease, transform 0.2s ease, background 0.2s ease;
  }
  .apps-tile:hover {
    border-color: rgba(251, 191, 36, 0.3);
    background: rgba(251, 191, 36, 0.03);
    transform: translateY(-2px);
  }
  .apps-tile-icon {
    color: var(--brand-gold);
    opacity: 0.85;
  }
  .apps-tile-name {
    font-size: 11px;
    color: var(--brand-muted);
  }
</style>
