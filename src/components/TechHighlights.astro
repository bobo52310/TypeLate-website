---
const highlights = [
  {
    title: "Privacy First",
    titleZh: "隱私優先",
    desc: "Your API key stays on your machine. Voice data goes directly from your mic to the AI provider. Zero telemetry servers.",
    descZh: "API Key 留在你的電腦。語音從麥克風直達 AI，零遙測伺服器。",
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 12 2 2 4-4"/></svg>`,
  },
  {
    title: "Open Source",
    titleZh: "開放原始碼",
    desc: "MIT Licensed. Inspect every line of code. Built with Tauri v2, React 19, and Rust.",
    descZh: "MIT 授權，程式碼完全透明。Tauri v2 + React 19 + Rust 打造。",
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>`,
  },
  {
    title: "Google Drive Sync",
    titleZh: "Google Drive 同步",
    desc: "Your custom vocabulary syncs across macOS and Android via Google Drive. Your personal dictionary follows you everywhere.",
    descZh: "自訂詞彙透過 Google Drive 在 macOS 與 Android 間同步，你的字典隨身帶著走。",
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 19.5h20L12 2z"/><path d="M2 19.5l5-8.5h10l5 8.5"/><path d="M7 11l5-9 5 9"/></svg>`,
  },
];
---

<section class="py-24 px-6">
  <div class="max-w-5xl mx-auto">
    <!-- Section title -->
    <div class="fade-in text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-2">
        <span class="lang-en">Built Different</span>
        <span class="lang-zh">不一樣的設計</span>
      </h2>
    </div>

    <!-- Cards -->
    <div class="fade-in grid grid-cols-1 md:grid-cols-3 gap-6">
      {
        highlights.map((h) => (
          <div
            class="fade-in-child feature-card rounded-2xl p-8 text-center"
            style="background: var(--brand-card); border: 1px solid var(--brand-border);"
          >
            {/* Icon */}
            <div
              class="w-14 h-14 rounded-2xl flex items-center justify-center mx-auto mb-5"
              style="background: rgba(251, 191, 36, 0.08); color: var(--brand-gold);"
            >
              <Fragment set:html={h.icon} />
            </div>

            {/* Title */}
            <h3 class="text-lg font-semibold mb-1">
              <span class="lang-en">{h.title}</span>
              <span class="lang-zh">{h.titleZh}</span>
            </h3>

            {/* Description */}
            <p class="text-sm leading-relaxed" style="color: var(--brand-muted);">
              <span class="lang-en">{h.desc}</span>
              <span class="lang-zh">{h.descZh}</span>
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
