---
import "../styles/global.css";
import { SITE, GITHUB_URL } from "../config/site";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = SITE.title,
  description = SITE.description,
} = Astro.props;

const siteName = SITE.name;
const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? SITE.url;
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const ogImage = `${siteUrl}/assets/og-image.png`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": SITE.name,
  "description": "Open-source voice-to-text app with AI post-processing. Press a hotkey, speak naturally, release — polished text appears where you type.",
  "url": siteUrl,
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "macOS, Windows, Android, iOS",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD",
  },
  "license": "https://opensource.org/licenses/MIT",
  "author": {
    "@type": "Person",
    "name": SITE.author,
    "url": SITE.authorUrl,
  },
  "downloadUrl": `${GITHUB_URL}/releases/latest`,
  "softwareVersion": "latest",
  "keywords": "voice to text, speech to text, dictation, AI transcription, open source, macOS, Windows, Android, BYOK, Groq, Whisper",
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="voice to text, speech to text, dictation, AI transcription, open source, macOS, Android, BYOK, Groq, Whisper, 語音轉文字, 語音輸入" />
    <meta name="author" content="Bobo Chen" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="TypeLate — Open-source voice-to-text with AI post-processing" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:locale:alternate" content="zh_TW" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="TypeLate — Open-source voice-to-text with AI post-processing" />

    <!-- Language alternates -->
    <link rel="alternate" hreflang="en" href={canonicalUrl} />
    <link rel="alternate" hreflang="zh-TW" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />

    <!-- Favicons -->
    <link rel="icon" type="image/png" href="/assets/logo-typelate.png" />
    <link rel="apple-touch-icon" href="/assets/logo-typelate.png" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="min-h-screen" style={`background: #0f172a;`}>
    <!-- Skip to content (accessibility) -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:rounded-lg focus:text-sm focus:font-semibold"
      style="background: var(--brand-gold); color: var(--brand-bg);"
    >
      Skip to content
    </a>
    <!-- Scroll progress indicator -->
    <div
      id="scroll-progress"
      class="fixed top-0 left-0 h-[2px] z-[60] pointer-events-none"
      style="background: linear-gradient(90deg, var(--brand-gold), var(--brand-gold-deep)); width: 0%;"
    ></div>

    <slot />

    <!-- Back to top button -->
    <button
      id="back-to-top"
      class="fixed bottom-6 right-6 z-50 w-10 h-10 rounded-full flex items-center justify-center transition-all duration-300 opacity-0 translate-y-4 pointer-events-none"
      style="background: var(--brand-card); border: 1px solid var(--brand-border); color: var(--brand-muted);"
      aria-label="Back to top"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="m18 15-6-6-6 6"/>
      </svg>
    </button>

    <!-- Scroll animation observer -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");

              // Stagger children
              const children =
                entry.target.querySelectorAll(".fade-in-child");
              children.forEach((child, i) => {
                setTimeout(() => {
                  child.classList.add("visible");
                }, i * 100);
              });

              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15 }
      );

      document.querySelectorAll(".fade-in").forEach((el) => {
        observer.observe(el);
      });

      // Nav scroll behavior + download button reveal + back to top + progress
      const nav = document.getElementById("main-nav");
      const navDownloadBtn = document.getElementById("nav-download-btn");
      const backToTop = document.getElementById("back-to-top");
      const scrollProgress = document.getElementById("scroll-progress");

      if (backToTop) {
        backToTop.addEventListener("click", () => {
          window.scrollTo({ top: 0, behavior: "smooth" });
        });
      }

      window.addEventListener("scroll", () => {
        const y = window.scrollY;

        // Nav blur on scroll
        if (nav) {
          nav.classList.toggle("nav-scrolled", y > 20);
        }

        // Show nav download button after scrolling past hero CTA
        if (navDownloadBtn) {
          const show = y > 500;
          navDownloadBtn.classList.toggle("opacity-0", !show);
          navDownloadBtn.classList.toggle("translate-y-1", !show);
          navDownloadBtn.classList.toggle("pointer-events-none", !show);
        }

        // Show back-to-top after scrolling down 800px
        if (backToTop) {
          const show = y > 800;
          backToTop.classList.toggle("opacity-0", !show);
          backToTop.classList.toggle("translate-y-4", !show);
          backToTop.classList.toggle("pointer-events-none", !show);
        }

        // Scroll progress bar
        if (scrollProgress) {
          const docHeight = document.documentElement.scrollHeight - window.innerHeight;
          const pct = docHeight > 0 ? Math.min((y / docHeight) * 100, 100) : 0;
          scrollProgress.style.width = `${pct}%`;
        }
      });

      // Language toggle
      function setLang(lang: string) {
        document.documentElement.setAttribute("data-lang", lang);
        document.documentElement.lang = lang === "zh" ? "zh-TW" : "en";
        localStorage.setItem("typelate-lang", lang);

        document.querySelectorAll("[data-lang-btn]").forEach((btn) => {
          const el = btn as HTMLElement;
          if (el.dataset.langBtn === lang) {
            el.style.background = "rgba(251, 191, 36, 0.15)";
            el.style.color = "var(--brand-gold)";
          } else {
            el.style.background = "transparent";
            el.style.color = "var(--brand-muted)";
          }
        });
      }

      document.querySelectorAll("[data-lang-btn]").forEach((btn) => {
        btn.addEventListener("click", () => {
          setLang((btn as HTMLElement).dataset.langBtn!);
        });
      });

      const savedLang =
        localStorage.getItem("typelate-lang") ||
        (navigator.language.startsWith("zh") ? "zh" : "en");
      setLang(savedLang);
    </script>
  </body>
</html>
