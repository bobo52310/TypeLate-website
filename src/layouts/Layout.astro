---
import "../styles/global.css";
import { SITE, GITHUB_URL } from "../config/site";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = SITE.title,
  description = SITE.description,
} = Astro.props;

const siteName = SITE.name;
const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? SITE.url;
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
// TODO: Create a proper 1200x630 PNG OG image. See public/assets/og-image.svg for design template.
const ogImage = `${siteUrl}/assets/logo-typelate.png`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": SITE.name,
  "description": "Open-source voice-to-text app with AI post-processing. Press a hotkey, speak naturally, release — polished text appears where you type.",
  "url": siteUrl,
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "macOS, Windows, Android, iOS",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD",
  },
  "license": "https://opensource.org/licenses/MIT",
  "author": {
    "@type": "Person",
    "name": SITE.author,
    "url": SITE.authorUrl,
  },
  "downloadUrl": `${GITHUB_URL}/releases/latest`,
  "softwareVersion": "latest",
  "keywords": "voice to text, speech to text, dictation, AI transcription, open source, macOS, Windows, Android, BYOK, Groq, Whisper",
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="voice to text, speech to text, dictation, AI transcription, open source, macOS, Android, BYOK, Groq, Whisper, 語音轉文字, 語音輸入" />
    <meta name="author" content="Bobo Chen" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="TypeLate — Open-source voice-to-text with AI post-processing" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:locale:alternate" content="zh_TW" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="TypeLate — Open-source voice-to-text with AI post-processing" />

    <!-- Language alternates -->
    <link rel="alternate" hreflang="en" href={canonicalUrl} />
    <link rel="alternate" hreflang="zh-TW" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />

    <!-- Favicons -->
    <link rel="icon" type="image/png" href="/assets/logo-typelate.png" />
    <link rel="apple-touch-icon" href="/assets/logo-typelate.png" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="min-h-screen" style={`background: #0f172a;`}>
    <slot />

    <!-- Scroll animation observer -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");

              // Stagger children
              const children =
                entry.target.querySelectorAll(".fade-in-child");
              children.forEach((child, i) => {
                setTimeout(() => {
                  child.classList.add("visible");
                }, i * 100);
              });

              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15 }
      );

      document.querySelectorAll(".fade-in").forEach((el) => {
        observer.observe(el);
      });

      // Nav scroll behavior + download button reveal
      const nav = document.getElementById("main-nav");
      const navDownloadBtn = document.getElementById("nav-download-btn");
      if (nav) {
        window.addEventListener("scroll", () => {
          const scrolled = window.scrollY > 20;
          nav.classList.toggle("nav-scrolled", scrolled);

          // Show nav download button after scrolling past hero CTA (~500px)
          if (navDownloadBtn) {
            const showBtn = window.scrollY > 500;
            navDownloadBtn.classList.toggle("opacity-0", !showBtn);
            navDownloadBtn.classList.toggle("translate-y-1", !showBtn);
            navDownloadBtn.classList.toggle("pointer-events-none", !showBtn);
          }
        });
      }

      // Language toggle
      function setLang(lang: string) {
        document.documentElement.setAttribute("data-lang", lang);
        document.documentElement.lang = lang === "zh" ? "zh-TW" : "en";
        localStorage.setItem("typelate-lang", lang);

        document.querySelectorAll("[data-lang-btn]").forEach((btn) => {
          const el = btn as HTMLElement;
          if (el.dataset.langBtn === lang) {
            el.style.background = "rgba(251, 191, 36, 0.15)";
            el.style.color = "var(--brand-gold)";
          } else {
            el.style.background = "transparent";
            el.style.color = "var(--brand-muted)";
          }
        });
      }

      document.querySelectorAll("[data-lang-btn]").forEach((btn) => {
        btn.addEventListener("click", () => {
          setLang((btn as HTMLElement).dataset.langBtn!);
        });
      });

      const savedLang =
        localStorage.getItem("typelate-lang") ||
        (navigator.language.startsWith("zh") ? "zh" : "en");
      setLang(savedLang);
    </script>
  </body>
</html>
